{
  "name": "zhaopin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/build.js",
    "build:cloudflare": "npx opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node ./scripts/deploy.js",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:wrangler": "npx wrangler deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "db:init": "wrangler d1 execute zhaopin --file=./scripts/init-db.sql",
    "db:seed": "wrangler d1 execute zhaopin --file=./scripts/seed-db.sql",
    "db:create": "wrangler d1 create zhaopin",
    "import:sqlite": "node ./scripts/import-json-to-sqlite.ts"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.100.0",
    "@opennextjs/cloudflare": "1.19.11"
  }
}
