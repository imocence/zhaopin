{
  "name": "zhaopin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && next export -o out",
    "start": "next start",
    "lint": "eslint",
    "db:init": "wrangler d1 execute zhaopin-db --file=./scripts/init-db.sql",
    "db:seed": "wrangler d1 execute zhaopin-db --file=./scripts/seed-db.sql",
    "db:create": "wrangler d1 create zhaopin-db",
    "import:sqlite": "node ./scripts/import-json-to-sqlite.ts"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3"
  }
}
